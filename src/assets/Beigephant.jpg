<script>
document.addEventListener("DOMContentLoaded", function () {
    function updateFloatingCart(variant) {
        if (!variant) return;

        // Update floating price
        const priceElement = document.querySelector(".floating-product-price");
        if (priceElement) {
            priceElement.innerHTML = "Rs. " + (variant.price / 100).toFixed(2);
        }

        // Update floating hidden variant ID
        const floatingVariantInput = document.querySelector(".floating-cart-button .variant-id");
        if (floatingVariantInput) {
            floatingVariantInput.value = variant.id;
        }

        // Update only the floating Add to Cart button
        const floatingAddToCartBtn = document.querySelector(".floating-cart-button [data-add-to-cart]");
        const floatingAddToCartText = document.querySelector(".floating-cart-button [data-add-to-cart-text]");
        
        if (variant.available) {
            floatingAddToCartBtn.removeAttribute("disabled");
            floatingAddToCartText.innerText = "Add to cart";
        } else {
            floatingAddToCartBtn.setAttribute("disabled", "disabled");
            floatingAddToCartText.innerText = "Out of Stock";
        }
    }

    // Function to get the initially selected variant in Shopify
    function getInitialVariant() {
        let selectedVariantId = document.querySelector("form[action='/cart/add'] [name='id']")?.value;
        return Shopify?.product?.variants.find(v => v.id == selectedVariantId);
    }

    // Shopify's built-in variant change event listener
    document.addEventListener("variant:change", function (event) {
        if (event.detail && event.detail.variant) {
            updateFloatingCart(event.detail.variant);
        }
    });

    // Force Update Floating Button with Shopify’s Pre-Selected Variant
    let initialVariant = getInitialVariant();
    if (initialVariant) {
        updateFloatingCart(initialVariant);
    }
});
</script>




