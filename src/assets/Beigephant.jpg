            && bitespeedLayer.ecommerce.detail.products[0]
        if (product) {
            if(hasLocalStorage) product.list_name = localStorage.list
                if(hasLocalStorage) product.list_id = localStorage.list
          var postData = {
            "at" : new Date(),
            "type" : "productViewed",
            "event" : product
          }
          analyticsPost(postData);
        }
    }
}
