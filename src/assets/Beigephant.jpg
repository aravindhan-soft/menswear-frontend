        <div class="sr-cart-checkout-button-container" data-type="cart">
          <div id="checkout-sticker"></div>
          <button class="mini-cart-order-btn" id="sr-buy-now-button" onclick="handleShiprocketSmartCartBuy()" style="background-color: rgb(0, 0, 0); border: 1px solid rgb(0, 0, 0); width: 100%; height: 50px; border-radius: 8px; font-size: 14px; color: rgb(255, 255, 255);">
            <div class="sr-cart-buy-now-content">
              <div class="flex-row buy-now-text-content">
                <span id="sr-buy-now-btn-text">Buy Now</span>
                <img src="./Beigephant_files/upi_options.svg" alt="Google Pay | Phone Pay | UPI" class="sr-cart-buy-btn-payment-icons" id="sr-cart-payment-icon" style="display: block;">
              </div>
