    align-items: flex-end !important;
  }

  .flex-start-column{
    align-items: start;
  }

  .text-right {
    text-align: right !important;
  }

  .text-left{
    text-align: left !important;
  }
  
  .milestone-dot {
    height: 10px;
    border-radius: 50%;
    top: -67px;
    transition: background-color 0.3s ease;
