<script id="rsi-cod-form-product-collections-cache" type="application/json">
  [{"id":230709919902,"handle":"best-seller","title":"BEST SELLER","updated_at":"2025-09-17T11:48:02+05:30","body_html":"","published_at":"2020-11-21T17:12:16+05:30","sort_order":"manual","template_suffix":"","disjunctive":false,"rules":[{"column":"tag","relation":"equals","condition":"Best seller"}],"published_scope":"web"},{"id":442562478337,"handle":"otto-products","title":"OTTO PRODUCTS","updated_at":"2025-09-17T11:49:15+05:30","body_html":"","published_at":"2025-03-20T13:35:34+05:30","sort_order":"created-desc","template_suffix":"","disjunctive":true,"rules":[{"column":"vendor","relation":"equals","condition":"OTTO"},{"column":"vendor","relation":"equals","condition":"OTTO Essentials"},{"column":"vendor","relation":"equals","condition":"ottostore.com"}],"published_scope":"web"},{"id":448212271361,"handle":"sharp-fit-trousers","title":"Sharp Fit - Trousers","updated_at":"2025-09-16T16:36:51+05:30","body_html":"","published_at":"2025-06-13T17:26:13+05:30","sort_order":"best-selling","template_suffix":"","disjunctive":false,"rules":[{"column":"tag","relation":"equals","condition":"Sharp Fit Chart"}],"published_scope":"web"},{"id":448205029633,"handle":"trim-fit-trousers","title":"Trim Fit - Trousers","updated_at":"2025-09-16T16:36:51+05:30","body_html":"","published_at":"2025-06-13T12:13:29+05:30","sort_order":"best-selling","template_suffix":"","disjunctive":false,"rules":[{"column":"tag","relation":"equals","condition":"Trim Fit Chart"}],"published_scope":"web"},{"id":211985432734,"handle":"trousers","title":"Trousers","updated_at":"2025-09-16T16:36:51+05:30","body_html":"\u003cp data-end=\"442\" data-start=\"378\"\u003e\u003cstrong data-end=\"440\" data-start=\"378\"\u003eSmart, Stylish \u0026amp; Comfortable – OTTO Trousers for Every Day\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp data-end=\"589\" data-start=\"258\"\u003eLooking to upgrade your everyday style? Explore OTTO’s premium collection of \u003cstrong data-end=\"359\" data-start=\"335\"\u003eMens Trousers Online\u003c\/strong\u003e, smart to meet the needs of the modern Indian man. Whether you're heading to work, stepping out casually, or dressing up for a special event, we’ve got you covered with versatile styles that combine comfort, fit, and elegance.\u003c\/p\u003e\n\u003cp data-end=\"937\" data-start=\"591\"\u003eAt OTTO, we bring you a wide selection of \u003cstrong data-end=\"653\" data-start=\"633\"\u003eTrousers for Men\u003c\/strong\u003e – from classic formals to relaxed casuals and everything in between. Our range includes expertly crafted \u003cstrong data-end=\"777\" data-start=\"759\"\u003eDenim Trousers\u003c\/strong\u003e, perfect for weekend outings or smart-casual settings. You’ll also find stylish \u003cspan style=\"text-decoration: underline;\"\u003e\u003ca href=\"https:\/\/www.ottostore.com\/collections\/denim-trousers\"\u003e\u003cstrong data-end=\"883\" data-start=\"858\"\u003ebranded jeans for men\u003c\/strong\u003e\u003c\/a\u003e\u003c\/span\u003e, made from high-quality fabrics and designed to last.\u003c\/p\u003e\n\u003cp data-end=\"1264\" data-start=\"939\"\u003ePrefer to keep it comfortable yet stylish? \u003ca href=\"https:\/\/www.ottostore.com\/collections\/casual-wear-trousers\"\u003e \u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong data-end=\"1012\" data-start=\"982\"\u003eBuy Casual Trousers Online\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e at OTTO and choose from a range of smart chinos, joggers, and stretch-fit trousers that move with you. Every piece is designed with attention to detail — be it the tailored cuts, stretchable waistbands, or breathable materials that offer all-day ease.\u003c\/p\u003e\n\u003cp data-end=\"1482\" data-start=\"1266\"\u003eWhen you \u003cstrong data-end=\"1303\" data-start=\"1275\"\u003eBuy Mens Trousers Online\u003c\/strong\u003e at OTTO, you're choosing a brand that stands for quality, value, and trust. Our trousers are built to complement your lifestyle—offering a seamless blend of function and fashion.\u003c\/p\u003e\n\u003cp data-end=\"1648\" data-start=\"1484\"\u003eDon’t just wear trousers—make a statement with OTTO. Explore our full range of \u003cstrong data-end=\"1580\" data-start=\"1563\"\u003eMens trousers\u003c\/strong\u003e and find the perfect fit for every occasion, only at \u003ca href=\"https:\/\/www.ottostore.com\/\"\u003eottostore.com\u003c\/a\u003e.\u003c\/p\u003e\n\u003ch3 data-end=\"187\" data-start=\"154\"\u003e\u003cstrong data-end=\"187\" data-start=\"158\"\u003eWhy Choose OTTO Trousers?\u003c\/strong\u003e\u003c\/h3\u003e\n\u003cp data-end=\"284\" data-start=\"191\"\u003e✅ \u003cstrong data-end=\"219\" data-start=\"193\"\u003eTailored for Precision\u003c\/strong\u003e – Impeccable cuts and fits designed for the modern Indian man.\u003c\/p\u003e\n\u003cp data-end=\"390\" data-start=\"287\"\u003e👔 \u003cstrong data-end=\"315\" data-start=\"290\"\u003eWork to Weekend Ready\u003c\/strong\u003e – Perfect for office formals, casual Fridays, and everything in between.\u003c\/p\u003e\n\u003cp data-end=\"485\" data-start=\"393\"\u003e💪 \u003cstrong data-end=\"417\" data-start=\"396\"\u003eBuilt for Comfort\u003c\/strong\u003e – Stretchable waistbands and breathable fabrics for all-day ease.\u003c\/p\u003e\n\u003cp data-end=\"583\" data-start=\"488\"\u003e🎨 \u003cstrong data-end=\"511\" data-start=\"491\"\u003eVersatile Styles\u003c\/strong\u003e – Choose from classic chinos, smart casuals, and trendy custom fits.\u003c\/p\u003e\n\u003cp data-end=\"662\" data-start=\"586\"\u003e🧵 \u003cstrong data-end=\"620\" data-start=\"589\"\u003ePremium Quality, Fair Price\u003c\/strong\u003e – Crafted with care, priced with value.\u003c\/p\u003e\n\u003cp data-end=\"754\" data-start=\"665\"\u003e💼 \u003cstrong data-end=\"696\" data-start=\"668\"\u003eTrusted by Professionals\u003c\/strong\u003e – A go-to brand for effortless everyday sophistication.\u003c\/p\u003e","published_at":"2020-08-03T16:00:52+05:30","sort_order":"manual","template_suffix":"","disjunctive":true,"rules":[{"column":"tag","relation":"equals","condition":"Casual Trousers"},{"column":"tag","relation":"equals","condition":"Denim Trousers"},{"column":"type","relation":"equals","condition":"Trousers"}],"published_scope":"web","image":{"created_at":"2020-08-03T17:15:52+05:30","alt":"","width":1080,"height":1440,"src":"\/\/www.ottostore.com\/cdn\/shop\/collections\/ott.jpg?v=1756117883"}},{"id":211985563806,"handle":"casual-trousers","title":"Work Wear Trousers","updated_at":"2025-09-16T16:36:51+05:30","body_html":"\u003cp data-mce-fragment=\"1\"\u003eShop the wide range of casual trousers at our online store. Our collections can be used as a party wear and also for numerous occasions. Our trousers are available with all the major colors which can combine well with shirts, Polos and casual T-shirts.\u003c\/p\u003e\n\u003cp data-mce-fragment=\"1\"\u003e Fill your wardrobe with our casual trousers today!\u003c\/p\u003e","published_at":"2020-08-03T16:01:32+05:30","sort_order":"manual","template_suffix":"","disjunctive":true,"rules":[{"column":"tag","relation":"equals","condition":"Casual Trousers"},{"column":"tag","relation":"equals","condition":"work wear"}],"published_scope":"web","image":{"created_at":"2023-07-06T12:23:43+05:30","alt":null,"width":1080,"height":1080,"src":"\/\/www.ottostore.com\/cdn\/shop\/collections\/Work-wear_1.jpg?v=1688626424"}}]
</script>



