.charticon {
  max-width: fit-content;
  min-width: fit-content;
  cursor: pointer;
  width: 14%;
  margin-right: 5pt;
}
.charticon-text {
  font-weight: 900 !important;
}
#dialogsize {
  margin: 0px;
  padding-right: 0px !important;
  padding-left: 0px !important;
}
.smartsizechart_content {
  height: 100% !important;
  margin: 10px;
}


/* Media query for mobile */
@media (max-width: 767px) {
  .smartsizechart_content {
    margin: 2px !important;
  }
}

#under_frame {
  width: 100%;
  border: none;
  height: 100%;
  //font-family: inherit;
  /* position: absolute; */
}
/* .opensize {
  margin-bottom: 10pt;
} */

.opencare {
  margin-bottom: 10pt;
}

#sizefox-container {
}

/* Title Bar of the pop-up: */
.ui-dialog .ui-dialog-titlebar {
  background-color: #fff !important;
  border: none !important;
  border-bottom: 1px solid #ffffff00 !important;
  border-radius: 0;
  margin-bottom: 4px;
  //font-family: inherit;
  font-variant-caps: titling-caps !important;
  font-weight: 800 !important;
  margin: 10px;
  color: #000000;
}

/* Close button on the pop-up:  */
.ui-dialog .ui-dialog-titlebar .ui-button {
  border: none !important;
  outline: none !important;
  background-color: transparent !important;
}

.smartsize_pop-up .ui-dialog-titlebar .ui-button-icon.ui-icon {
  background-image: url(https://dev-client.smartsize.io/close.png) !important;
  background-position: center;
  background-size: 24px;
}

.ui-dialog .ui-dialog-content {
  max-height: 90vh !important;
  padding-left: 40px !important;
  padding-right: 40px !important;
}

/* Adding round corners to the whole pop-up */
.ui-dialog.smartsize_pop-up.ui-widget.ui-widget-content.ui-front {
  border-radius: 6px !important;
  /*left: calc(100% - 676px) !important;
  top: 0px !important;
  height: 100% !important; */

  top: 2% !important;
  bottom: 2% !important;

  min-height: 50%;
  height: auto !important;
  box-shadow: rgba(0, 0, 0, 0.16) 0px 10px 36px 0px,
    rgba(0, 0, 0, 0.06) 0px 0px 0px 1px;
}

.smartsize_pop-up {
  /* max-width: 676px !important; */
  overflow: hidden;
  //width: 676px !important;
  position: fixed !important;
  z-index: 100000;
}

.smartsize_pop-up_small {
  width: 50% !important;
}

.smartsize_pop-up_medium {
  width: 70% !important;
}

.smartsize_pop-up_large {
  width: 85% !important;
}

.smartsize_pop-up_maximum {
  overflow: hidden;
  width: 100% !important;
  position: fixed !important;
  z-index: 100000;
}

/* .smartsizechart_content {
  overflow-x: hidden;
} */
.smartsize-button-text {
  cursor: pointer;
  margin-right: 10px;
  margin-top: 5px;
  text-decoration: underline;
}

/*
.sizechart_title {
  text-align: center;
  font-size: xx-large !important;
}
*/

.carechart_content {
  overflow-x: auto;
}

.sizechart_wrapper {
  overflow-y: unset !important;
  overflow-x: auto !important;
  position: relative;
  padding-top: 10px;
}

table.sizechart {
  table-layout: fixed;
  width: auto;
  margin-left: auto;
  margin-right: auto;
  border-top: 2px solid #cccdcd;
  border-bottom: 2px solid #cccdcd;
  border-spacing: 0px;
  background: none !important;
  font-weight: 500 !important;
  color: black;
  //font-family: inherit;
  margin-bottom: 10px !important;
}

table.sizechart tr td {
  border: none !important;
  white-space: nowrap;
  /* background: no-repeat !important; */
  /*media sepecific */

  /* padding: 10px 14px; */
  cursor: pointer;
  user-select: none;
  text-align: center;
  text-decoration-color: blue;
}
/* table.sizechart td:first-child {
  text-align: left;
} */
table.sizechart tr:first-child td:not(:first-child) {
  /* width: 100px; */
  min-width: 100px;
  text-align: center;
}

table.sizechart tr td:first-child {
  pointer-events: none;
  position: sticky;
  left: 0;
  background-color: white;
  /* border-right: 1px solid #000000 !important; */
  padding-left: 10px !important;
  padding-right: 20px !important;
  padding-top: 20px !important;
  padding-bottom: 20px !important;
  text-align: start;
}

/* To change background color of the odd lines of the table: */

table.sizechart tr:nth-child(odd) {
  /* background-color: #ebeef0; */
  background-color: #eceeee;
}
table.sizechart tr:nth-child(odd) td:first-child {
  /* background-color: #ebeef0; */

  background-color: #eceeee;
}

/* To change background color of the first line of the table: */
table.sizechart tr:first-child {
  color: white;
  font-weight: 600 !important;
}
table.sizechart tr:first-child td:first-child {
  color: white;
  font-weight: 600 !important;
}

table.sizechart td.sizefox-td-hover span {
  color: #fff !important;
  padding: 10px;
  border-radius: 50px;
  min-width: 33px;
}

.sizechart_wrapper .sizefox-td-click span {
  font-weight: 500 !important;
  padding: 8px;
  border-radius: 50px;
  min-width: 33px;
}

table.switcher {
  table-layout: fixed;
  width: auto;
  margin-left: auto;
  margin-right: auto;
  border-top: 2px solid #cccdcd;
  border-bottom: 2px solid #cccdcd;
  border-spacing: 0px;
  background: none;
  font-weight: 500;
  color: black;
  margin-bottom: 10px;
  max-width: 95%;
  width: 100%;
}

table.switcher tr td {
  border: none;
  white-space: nowrap;
  background: none;
  /* media sepecific */

  /* padding: 10px 14px; */
  cursor: pointer;
  user-select: none;
  text-align: center;
}
table.switcher td:first-child {
  text-align: left;
}
table.switcher tr:first-child td:not(:first-child) {
  width: 100px;
  min-width: 100px;
  text-align: center;
  background: #000000;
}

table.switcher tr td:first-child {
  pointer-events: none;
  position: sticky;
  left: 0;
  background-color: white;
  /* border-right: 1px solid #000000; */
  padding-left: 10px;
  padding-right: 50px;
  padding-top: 20px;
  padding-bottom: 20px;
}

/* To change background color of the odd lines of the table: */

table.switcher tr:nth-child(odd) {
  /* background-color: #ebeef0; */
  background-color: #eceeee;
}
table.switcher tr:nth-child(odd) td:first-child {
  /* background-color: #ebeef0; */

  background-color: #eceeee;
}

/* To change background color of the first line of the table: */
table.switcher tr:first-child {
  background-color: #000000;
  color: white;
  font-weight: 600;
}
table.switcher tr:first-child td:first-child {
  background-color: #000000;
  color: white;
  font-weight: 600;
}

table.switcher td.sizefox-td-hover span {
  background: #000000;
  color: #fff;
  padding: 10px;
  border-radius: 50px;
  min-width: 33px;
}
table.switcher td span {
  padding: 10px;
  border-radius: 50px;
  min-width: 33px;
}

/* --- Switch Style --- */
.sizechart_switch {
  width: 100%;
  display: flex;
  justify-content: right;
  margin-top: 20px;
}

.switch_wrapper {
  display: flex;
  -webkit-box-align: center;
  align-items: center;
}

.switch_wrapper .switch {
  position: relative;
  display: flex;
}

.switch_wrapper .switch input {
  opacity: 0;
  width: 0;
  height: 0;
  display: none;
}

.switch_wrapper .switch .slider {
  position: relative;
  display: inline-block;
  width: 27px;
  height: 17px;
  border: none;
  background: rgb(0, 0, 0);
  appearance: none;
  border-radius: 27px;
  position: relative;
  padding: 0px;
  margin: 0px;
  cursor: pointer;
  outline: none;
}

.switch_wrapper .switch .slider:before {
  position: absolute;
  content: "";
  top: 1px;
  left: 1px;
  height: 15px;
  width: 15px;
  border-radius: 50%;
  background-color: white;
  -webkit-transition: 0.4s;
  transition: 0.4s;
}

.switch_wrapper .switch input:checked + .slider:before {
  -webkit-transform: translateX(10px);
  -ms-transform: translateX(10px);
  transform: translateX(10px);
}
.switch_wrapper .unit {
  padding: 4px;
  //font-family: inherit;
  color: rgb(0, 0, 0);
}
/* --- Switch Style --- */

.smartsize_pop-up {
  //font-family: inherit;
}

table.sizechart td.sizefox-nohover hr {
  margin: 20px 0;
}

table.sizechart td.sizefox-nohover p + hr + p + p {
  display: none;
  margin-bottom: 17px;
}

table.sizechart td.sizefox-nohover p + hr + p + p + p {
  margin-top: 45px;
}

table.sizechart tr.bttm-border {
  /* border-style: hidden !important; */
  border-bottom: 5px solid black;
}

.sizechart {
  margin-bottom: 0px !important;
}

table.bttm-border td {
  border-right: hidden !important;
  border-left: hidden !important;
}

table.tab-border {
  border-bottom: 5px solid pink;
}

/* .smartsizechart_instruction {
  margin-top: 10px !important;
  vertical-align: top;
} */
/* .smartsizechart_instruction > p {
  margin: 0px !important;
} */

.smartsizechart_content .smartsizechart_instruction table {
  width: auto !important;
  /* position: absolute;
  right: 0;
  left: 0; */
}

.smartsizechart_content .smartsizechart_instruction table tbody tr img {
  width: 100%;
  /* height: 100%; */
  object-fit: contain;
  vertical-align: top;

}

@media (max-width: 1024px) {
  table.sizefoxnoclasstable.sizefoxtable-image {
    display: block;
    width: 100% !important;
    border-color: inherit;
  }

  table.sizefoxnoclasstable.sizefoxtable-image td {
    width: 50% !important;
    float: left;
  }

  table.sizefoxnoclasstable.sizefoxtable-image td img {
    width: 100%;
    height: auto;
  }

  /* .smartsizechart_content .smartsizechart_instruction table tbody tr td {
    width: 100% !important;
    display: flex;
    flex-wrap: wrap;
  } */
  /* table.sizechart {
    width: 100%;
  } */

  table.sizechart tr td {
    padding: 10px 20px;
  }
}

@media (max-width: 600px) {
  .smartsize_pop-up {
    inset: 5px !important;
    width: auto !important;
  }
}

@media (max-width: 767px) {
  
  .ui-dialog .ui-dialog-content {
    max-height: calc(100vh - 60px) !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }
  td.sizefox-nohover p + hr + p + p + p {
    margin-top: 45px;
  }

  table.sizefoxnoclasstable td {
    padding: 10px 5px !important;
  }

  table.sizefoxnoclasstable.sizefoxtable-image td {
    width: 98% !important;
    float: left;
  }
  table.sizefoxnoclasstable.sizefoxtable-image {
    width: 100% !important;
    display: block;
    border-color: inherit;
  }
  table.sizefoxnoclasstable.sizefoxtable-image img {
    width: 280px;
    height: auto;
  }

  table.sizechart {
    width: auto !important;
  }
  table.sizechart tr td {
    padding: 5px 15px;
  }
  table.sizechart tr td:first-child {
    padding-right: 10px !important;
  }

  .smartsizechart_instruction p img,
  .smartsizechart_content div p img {
    width: 100% !important;
    height: auto;
    /* object-fit: scale-down; */
  }
}

#smartsize-dialog {
  padding: 0.2em;
  margin-left: 0.2em;
  margin-right: 0.2em;

}


/* .smartsizechart_instruction table *,
.smartsizechart_instruction {
  border: 0 !important;
  box-shadow: none !important;
  line-height: 1.8;
} */

@media (max-width: 480px) {
  table.sizechart {
    width: auto;
    //font-size: 12px !important;
  }

  table.sizechart tr:first-child td:not(:first-child) {
    min-width: 50px;
    width: 100px;
  }
  #under_frame {
    overflow: scroll;
    overflow-x: hidden;
  }
  /* ::-webkit-scrollbar { */
  /* width: 0; Remove scrollbar space */
  /* background: transparent; Optional: just make scrollbar invisible */
  /* } */
  .smartsizechart_content::-webkit-scrollbar-thumb {
    /* background: none !important; */
    /* ranko removed disabling for mobile scrollbar */
  }
  .smartsizechart_content .smartsizechart_instruction table tbody tr {
    display: flex;
    flex-wrap: wrap;
  }
  .smartsizechart_content .smartsizechart_instruction table tbody tr td {
    padding: 0px;
    padding-left: 10px;
    width: 100% !important;
  }
}

/* Scrollbar styling */
/* width */

.smartsizechart_content::-webkit-scrollbar {
  width: 5px;
  height: 5px;
}

/* Track */

.smartsizechart_content::-webkit-scrollbar-track {
  box-shadow: inset 0 0 5px #ffffff00;
  border-radius: 20px;
}

/* Handle */

.smartsizechart_content::-webkit-scrollbar-thumb {
  background: #c4c4c4;
  border-radius: 10px;
}

/* Handle on hover */

.smartsizechart_content::-webkit-scrollbar-thumb:hover {
  background: #a0a0a0;
  overflow: hidden; /* Hide vertical scrollbar */
}

div#conversions_em_bs_root {
  position: fixed;
  width: 100%;
  height: 100vh;
  background-color: #000000d1;
  top: 0;
  left: 0;
  z-index: 9;
  display: none;
}

body.backdrop_sizefox:after {
  position: fixed;
  left: 0;
  width: 100%;
  height: 100%;
  content: "";
  background: #01010178;
  z-index: 9;
}

.smartsizechart_instruction p img,
.smartsizechart_content div p img {
  max-width: 100%;
  height: auto;
  /* object-fit: scale-down; */
}
.ui-dialog .ui-dialog-title {
  white-space: normal !important;
  width: 100% !important;
  margin: 0px;
}

/*
.sizefox-product-title {
  margin: 0px;
  text-align: center !important;
  font-family: inherit;
  font-weight: 800 !important;
  font-size: 11px; 
}
*/

.ui-dailog-popup-title-head {
  margin-top: 0px !important;
  margin-bottom: 0px !important;
}
.sizefox-btn-top {
  margin-top: 0px;
  margin-bottom: 10pt;
}
.sizefox-btn-center {
  margin-top: 5pt;
  margin-bottom: 5pt;
}
.sizefox-btn-bottom {
  margin-top: 10pt;
  margin-bottom: 0px;
}

.sizefox-container-flex {
  display: flex;
  align-items: center;
}
.sizefox-container-left {
  justify-content: left;
}
.sizefox-container-center {
  justify-content: center;
}
.sizefox-container-right {
  justify-content: right;
}

.zsiq_prv_main * {
  /* font-family: inherit; */
}

.smartsizechart_instruction_default {
  font-family: 'Open Sans';
}

.smartsizechart_instruction_inherit {
  font-family: inherit !important;
