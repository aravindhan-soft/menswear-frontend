  #amount {
    width: 100%;
    padding: 10px;
    margin-top: 40px;
    font-size: 16px;
    border: 1px solid #ddd;
    border-radius: 4px;
  }

  .progress-bar-heading{
    margin-top: 10px;
    font-family: "Open Sans", sans-serif !important;
    font-size: 14px;
    line-height: 12px;
    text-align: center;
