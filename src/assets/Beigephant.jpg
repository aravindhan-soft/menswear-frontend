            <div>
              <div class="sr-upsell-item">
                <div class="sr-upsell-image-wrapper" data-variant-id="46552790532353" data-has-multiple-variants="true" data-product-index="2" data-view-info="true">
                  <img class="product-img" src="https://cdn.shopify.com/s/files/1/0448/1856/3230/files/ADS09168.jpg?v=1753342102" alt="product_img">
                </div>
                <div class="sr-upsell-item-detail">
                  <div style="display: flex; justify-content: space-between;">
                    <p class="sr-upsell-item-name">Navy Printed Casual Shirt - 38</p>
                  </div>
                  <div style="display: flex; justify-content: space-between;">
                    <div class="sr-upsell-item-price-container">
                      <div style="text-overflow: ellipsis;"><span class="sr-upsell-item-current-price">₹1899</span></div>
                    </div>
                    <button class="sr-upsell-item-action" data-variant-id="46552790532353" data-has-multiple-variants="true" data-product-index="2">
