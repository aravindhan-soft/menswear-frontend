rong\u003eMaterial\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8887%; height: 19.6px;\"\u003eSatin\/Cotton Blend\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: 39.2px;\"\u003e\n\u003cth style=\"width: 13.0953%; height: 39.2px;\"\u003e\u003cstrong\u003eFront Pleat\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8841%; height: 39.2px;\"\u003eFeaturing Flat Front Styling\u003c\/td\u003e\n\u003cth style=\"width: 10.7231%; height: 39.2px;\"\u003e\u003cstrong\u003eWaist\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8887%; height: 39.2px;\"\u003eConstructed inner waistband\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: 19.6px;\"\u003e\n\u003cth style=\"width: 13.0953%; height: 19.6px;\"\u003e\u003cstrong\u003ePockets\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8841%; height: 19.6px;\"\u003eDouble welt Back Pocket\u003c\/td\u003e\n\u003cth style=\"width: 10.7231%; height: 19.6px;\"\u003e\u003cstrong\u003eLength\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8887%; height: 19.6px;\"\u003eRegular\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: 19.6px;\"\u003e\n\u003cth style=\"width: 13.0953%; height: 19.6px;\"\u003ePattern\u003c\/th\u003e\n\u003ctd style=\"width: 31.8841%; height: 19.6px;\"\u003eSolid\u003c\/td\u003e\n\u003cth style=\"width: 10.7231%; height: 19.6px;\"\u003e\u003cstrong\u003eOccasion\u003c\/strong\u003e\u003c\/th\u003e\n\u003ctd style=\"width: 31.8887%; height: 19.6px;\"\u003eFormal\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: 39.2px;\"\u003e\n\u003cth style=\"width: 13.0953%; height: 39.2px;\"\u003eLogo\u003c\/th\u003e\n\u003ctd style=\"width: 31.8841%; height: 39.2px;\"\u003eMetal logo trim at front loop\u003c\/td\u003e\n\u003cth style=\"width: 10.7231%; height: 39.2px;\"\u003eCare\u003c\/th\u003e\n\u003ctd style=\"width: 31.8887%; height: 39.2px;\"\u003eRegular\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003c\/tbody\u003e\n\u003c\/table\u003e\n\u003cp\u003e \u003c\/p\u003e"}
