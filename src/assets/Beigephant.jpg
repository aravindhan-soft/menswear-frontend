                  </div>
                  <div style="display: flex; justify-content: space-between;">
                    <div class="sr-upsell-item-price-container">
                      <div style="text-overflow: ellipsis;"><span class="sr-upsell-item-current-price">₹1699</span></div>
                    </div>
                    <button class="sr-upsell-item-action" data-variant-id="46651843117313" data-has-multiple-variants="true" data-product-index="0">
                      +5 options
                    </button>
                  </div>
                </div>
              </div>
            </div>          
          
            <div>
              <div class="sr-upsell-item">
                <div class="sr-upsell-image-wrapper" data-variant-id="46674460770561" data-has-multiple-variants="true" data-product-index="1" data-view-info="true">
                  <img class="product-img" src="https://cdn.shopify.com/s/files/1/0448/1856/3230/files/KMB00804.jpg?v=1756383735" alt="product_img">
                </div>
                <div class="sr-upsell-item-detail">
                  <div style="display: flex; justify-content: space-between;">
                    <p class="sr-upsell-item-name">Sky Blue Printed Polo T Shirt - M</p>
                  </div>
                  <div style="display: flex; justify-content: space-between;">
                    <div class="sr-upsell-item-price-container">
                      <div style="text-overflow: ellipsis;"><span class="sr-upsell-item-current-price">₹1299</span></div>
                    </div>
                    <button class="sr-upsell-item-action" data-variant-id="46674460770561" data-has-multiple-variants="true" data-product-index="1">
                      +4 options
