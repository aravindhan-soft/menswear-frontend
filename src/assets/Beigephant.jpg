}

#bill-summary-arrow {
  height: 7px;
  color: #9A9A9A
}

.sr-cart-buy-btn-payment-icons {
  margin-left: 5px;
  display: none;
}

.sr-cart-buy-now-content {
  display: flex;
  justify-content: center;
  align-items: center;
}

.combined-offer-badge {
